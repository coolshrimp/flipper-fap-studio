{
  "name": "flipper-fap-studio",
  "displayName": "Flipper FAP Studio",
  "description": "GUI-first VS Code extension for building, previewing, launching, and managing Flipper Zero .fap apps without the command line",
  "version": "0.13.6",
  "publisher": "coolshrimp",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/coolshrimp/flipper-fap-studio.git"
  },
  "bugs": {
    "url": "https://github.com/coolshrimp/flipper-fap-studio/issues"
  },
  "homepage": "https://github.com/coolshrimp/flipper-fap-studio#readme",
  "keywords": [
    "flipper",
    "flipper zero",
    "fap",
    "ufbt",
    "firmware",
    "embedded",
    "momentum",
    "unleashed",
    "roguemaster"
  ],
  "pricing": "Free",
  "galleryBanner": {
    "color": "#1e1b2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "flipperFapStudio",
          "title": "Flipper FAP Studio",
          "icon": "media/flipper-icon.svg"
        }
      ]
    },
    "views": {
      "flipperFapStudio": [
        {
          "id": "flipperMain",
          "name": "Flipper FAP Studio",
          "type": "tree"
        },
        {
          "id": "flipperScreen",
          "name": "Live Screen + Log",
          "type": "webview",
          "visibility": "collapsed"
        },
        {
          "id": "flipperDeviceFiles",
          "name": "Flipper Files (on Device)",
          "type": "tree"
        },
        {
          "id": "flipperRecentProjects",
          "name": "Recent Projects",
          "type": "tree"
        },
        {
          "id": "flipperFirmwareStatus",
          "name": "Firmware SDKs",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "flipperFapStudio.installUfbt",
        "title": "Install / Update uFBT",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.build",
        "title": "Build .fap",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.buildAndLaunch",
        "title": "Build + Launch on Flipper",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.clean",
        "title": "Clean",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.openDist",
        "title": "Open dist folder",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.createStarterApp",
        "title": "Create starter app",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.selectTarget",
        "title": "Select firmware target",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.pickAppFolder",
        "title": "Set app folder…",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.openSettings",
        "title": "Settings",
        "icon": "$(settings-gear)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.openGuide",
        "title": "Guide",
        "icon": "$(book)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.cancelBuild",
        "title": "Cancel Build",
        "icon": "$(stop-circle)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.recent.setActive",
        "title": "Set as Current App Folder",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.recent.openWindow",
        "title": "Open in New Window",
        "icon": "$(empty-window)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.recent.remove",
        "title": "Remove from Recent",
        "icon": "$(close)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.fw.setPath",
        "title": "Set SDK Path",
        "icon": "$(folder-opened)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.fw.openGitHub",
        "title": "GitHub Releases",
        "icon": "$(cloud-download)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.fw.openWebPage",
        "title": "Open Update Page",
        "icon": "$(link-external)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.screen.open",
        "title": "Live Screen Preview",
        "icon": "$(device-camera-video)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.designer.open",
        "title": "UI Designer",
        "icon": "$(layout)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.dashboard.open",
        "title": "Device Dashboard",
        "icon": "$(dashboard)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.simulator.open",
        "title": "Flipper Simulator",
        "icon": "$(debug-alt)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.screen.openTab",
        "title": "Open Screen in Editor Tab",
        "icon": "$(link-external)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.serial.startLog",
        "title": "Start Serial Log",
        "icon": "$(play)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.serial.stopLog",
        "title": "Stop Serial Log",
        "icon": "$(stop)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.serial.disconnect",
        "title": "Disconnect Flipper Serial",
        "icon": "$(debug-disconnect)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.files.refresh",
        "title": "Refresh Flipper Files",
        "icon": "$(refresh)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.files.open",
        "title": "Open File from Flipper",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.files.upload",
        "title": "Upload Files Here…",
        "icon": "$(cloud-upload)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.files.uploadFolder",
        "title": "Upload Folder Here…",
        "icon": "$(file-symlink-directory)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.files.revealApp",
        "title": "Reveal Current App on Device",
        "icon": "$(target)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.files.download",
        "title": "Download…",
        "icon": "$(cloud-download)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.files.mkdir",
        "title": "New Folder…",
        "icon": "$(new-folder)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.files.rename",
        "title": "Rename…",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.files.delete",
        "title": "Delete",
        "icon": "$(trash)",
        "category": "Flipper FAP Studio"
      },
      {
        "command": "flipperFapStudio.files.copyPath",
        "title": "Copy Device Path",
        "category": "Flipper FAP Studio"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "flipperFapStudio.openSettings",
          "when": "view == flipperMain",
          "group": "navigation@1"
        },
        {
          "command": "flipperFapStudio.openGuide",
          "when": "view == flipperMain",
          "group": "navigation@2"
        },
        {
          "command": "flipperFapStudio.refresh",
          "when": "view == flipperMain",
          "group": "navigation@3"
        },
        {
          "command": "flipperFapStudio.screen.openTab",
          "when": "view == flipperScreen",
          "group": "navigation@1"
        },
        {
          "command": "flipperFapStudio.serial.disconnect",
          "when": "view == flipperScreen",
          "group": "navigation@2"
        },
        {
          "command": "flipperFapStudio.files.revealApp",
          "when": "view == flipperDeviceFiles",
          "group": "navigation@1"
        },
        {
          "command": "flipperFapStudio.files.upload",
          "when": "view == flipperDeviceFiles",
          "group": "navigation@2"
        },
        {
          "command": "flipperFapStudio.files.refresh",
          "when": "view == flipperDeviceFiles",
          "group": "navigation@3"
        },
        {
          "command": "flipperFapStudio.files.uploadFolder",
          "when": "view == flipperDeviceFiles",
          "group": "1_ops@1"
        },
        {
          "command": "flipperFapStudio.files.mkdir",
          "when": "view == flipperDeviceFiles",
          "group": "1_ops@2"
        }
      ],
      "view/item/context": [
        {
          "command": "flipperFapStudio.files.upload",
          "when": "view == flipperDeviceFiles && viewItem == flipperDir",
          "group": "inline@1"
        },
        {
          "command": "flipperFapStudio.files.download",
          "when": "view == flipperDeviceFiles && viewItem == flipperFile",
          "group": "inline@1"
        },
        {
          "command": "flipperFapStudio.files.mkdir",
          "when": "view == flipperDeviceFiles && viewItem == flipperDir",
          "group": "1_ops@1"
        },
        {
          "command": "flipperFapStudio.files.upload",
          "when": "view == flipperDeviceFiles && viewItem == flipperDir",
          "group": "1_ops@2"
        },
        {
          "command": "flipperFapStudio.files.uploadFolder",
          "when": "view == flipperDeviceFiles && viewItem == flipperDir",
          "group": "1_ops@3"
        },
        {
          "command": "flipperFapStudio.files.download",
          "when": "view == flipperDeviceFiles && viewItem == flipperFile",
          "group": "1_ops@3"
        },
        {
          "command": "flipperFapStudio.files.rename",
          "when": "view == flipperDeviceFiles && viewItem =~ /^flipper(Dir|File)$/",
          "group": "2_edit@1"
        },
        {
          "command": "flipperFapStudio.files.delete",
          "when": "view == flipperDeviceFiles && viewItem =~ /^flipper(Dir|File)$/",
          "group": "2_edit@2"
        },
        {
          "command": "flipperFapStudio.files.copyPath",
          "when": "view == flipperDeviceFiles && viewItem =~ /^flipper(Dir|File)$/",
          "group": "3_util@1"
        },
        {
          "command": "flipperFapStudio.recent.openWindow",
          "when": "view == flipperRecentProjects && viewItem == recentProject",
          "group": "inline@1"
        },
        {
          "command": "flipperFapStudio.recent.remove",
          "when": "view == flipperRecentProjects && viewItem == recentProject",
          "group": "inline@2"
        },
        {
          "command": "flipperFapStudio.fw.setPath",
          "when": "view == flipperMain && viewItem =~ /^fw-(?!oem)/",
          "group": "inline@1"
        },
        {
          "command": "flipperFapStudio.fw.openGitHub",
          "when": "view == flipperMain && viewItem =~ /^fw-/",
          "group": "inline@2"
        },
        {
          "command": "flipperFapStudio.fw.openWebPage",
          "when": "view == flipperMain && viewItem =~ /^fw-/",
          "group": "inline@3"
        }
      ]
    },
    "configuration": {
      "title": "Flipper FAP Studio",
      "properties": {
        "flipperFapStudio.defaultAppFolder": {
          "type": "string",
          "default": "",
          "description": "Default folder containing the Flipper app source"
        },
        "flipperFapStudio.desktopRuntime.compilerPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to gcc/gcc.exe for Functional Simulator mode. Pico SDK MinGW and GCC on PATH are detected automatically."
        },
        "flipperFapStudio.stm32Runtime.executablePath": {
          "type": "string",
          "default": "",
          "description": "Optional override path to a compatible nviennot/stm32-emulator executable. The Windows build bundled with the extension is used when blank."
        },
        "flipperFapStudio.stm32Runtime.maxInstructions": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Optional ARM instruction limit for firmware sessions. Zero keeps the emulator running until Stop Simulator is pressed."
        },
        "flipperFapStudio.serialPort": {
          "type": "string",
          "default": "",
          "description": "COM port of the Flipper Zero (e.g. COM3). Leave blank to auto-detect."
        },
        "flipperFapStudio.defaultTarget": {
          "type": "string",
          "default": "oem",
          "description": "Active firmware build target"
        },
        "flipperFapStudio.askOnBuildOutput": {
          "type": "boolean",
          "default": false,
          "description": "Prompt for an output folder after every successful build so you can copy the .fap anywhere"
        },
        "flipperFapStudio.buildOutputDir": {
          "type": "string",
          "default": "",
          "description": "Automatically copy the built .fap to this directory after each successful build (ignored when askOnBuildOutput is enabled)"
        },
        "flipperFapStudio.defaultCreateAppDir": {
          "type": "string",
          "default": "",
          "description": "Default parent folder offered when creating a new starter app (leave blank to always browse)"
        },
        "flipperFapStudio.targets.rogueMasterPath": {
          "type": "string",
          "default": "C:\\Flipper\\RogueMaster",
          "description": "Path to RogueMaster firmware SDK"
        },
        "flipperFapStudio.targets.momentumPath": {
          "type": "string",
          "default": "C:\\Flipper\\Momentum",
          "description": "Path to Momentum firmware SDK"
        },
        "flipperFapStudio.targets.unleashedPath": {
          "type": "string",
          "default": "C:\\Flipper\\Unleashed",
          "description": "Path to Unleashed firmware SDK"
        },
        "flipperFapStudio.targets.custom": {
          "type": "array",
          "default": [],
          "description": "Custom firmware target paths",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "path": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test:simulator": "npm run compile && node tests/buildState.test.js && node tests/ufbtRunner.test.js && node tests/simulatorParser.test.js && node tests/simulatorMp3Regression.test.js && node tests/simulatorPanelHtml.test.js && node tests/webviewTheme.test.js && node tests/storageVolumes.test.js && node tests/firmwareResources.test.js && node tests/fat16Image.test.js && node tests/stm32Runtime.test.js && node tests/runtimeWorkspace.test.js && node tests/desktopRuntimeCompatibility.test.js",
    "package": "vsce package",
    "deploy": "vsce package && powershell -Command \"code --install-extension (Get-ChildItem *.vsix | Sort-Object LastWriteTime -Descending | Select-Object -First 1).Name --force\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "serialport": "^12.0.0",
    "webbluetooth": "^3.7.0"
  }
}
